# Copy this file to front/.env.local for local Vite runs.
# Never commit real key values.

VITE_KAKAO_MAP_ENABLED=false
VITE_KAKAO_JAVASCRIPT_KEY=

# Optional local dev proxy target for Vite.
# Use this when Spring Boot runs on a non-default port such as 8081.
VITE_BACKEND_PROXY_TARGET=http://localhost:8080
