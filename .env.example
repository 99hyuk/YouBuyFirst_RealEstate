# Copy this file to .env for local runs. Never commit real secret values.

# Public Data Portal service key for MOLIT real-estate APIs.
DATA_GO_SERVICE_KEY=

# Kakao map keys for local map prototype work.
# Backend/server-side calls should use KAKAO_REST_API_KEY if needed.
# Vite frontend reads VITE_KAKAO_JAVASCRIPT_KEY from front/.env.local.
KAKAO_REST_API_KEY=
KAKAO_JAVASCRIPT_KEY=
KAKAO_NATIVE_APP_KEY=

# --- 적재/갱신 주기 ---
# 실거래(MOLIT): 월 단위 발행 + 최근 달 지각신고 → 하루 1회 갱신이면 충분.
#   기동 시 realestate-seed가 1회 멱등 적재, realestate-refresh가 현재월을 주기 재수집.
REALESTATE_REFRESH_INTERVAL_MINUTES=1440
REALESTATE_CURRENT_DEAL_YM=202605
# 커뮤니티 반응 크롤링/분석: 변동이 빨라 6시간(360분) 주기. 크롤 키(SERPAPI/NAVER),
#   분석 키(GMS)가 있어야 의미 있는 결과가 나오므로 ENABLE 플래그를 켤 때 키도 채우기.
CRAWL_INTERVAL_MINUTES=360

# Optional defaults for pipeline real-estate public data commands.
REALESTATE_LAWD_CODE=11110
REALESTATE_DEAL_YM=202606
REALESTATE_DATASETS=trade,rent
REALESTATE_USE_BACKEND_TARGETS=false
REALESTATE_LEGAL_DONG_CODE_CSV=
REALESTATE_MARKET_FACTS_JSONL=
REALESTATE_MARKET_FACT_REFRESH_ENABLED=false
REALESTATE_MARKET_FACT_REFRESH_INTERVAL_MINUTES=360
REALESTATE_PUBLIC_DATA_TIMEOUT_SECONDS=20
REALESTATE_PUBLIC_DATA_MAX_RETRIES=1
REALESTATE_PUBLIC_DATA_RETRY_BACKOFF_SECONDS=1
REALESTATE_REB_RONE_TIMEOUT_SECONDS=20
REALESTATE_RONE_GEO_CODE=10

# Optional real-estate matcher/reaction snapshot refresh.
# Set REALESTATE_USE_BACKEND_ALIASES=true to read approved, non-ambiguous aliases from backend.
REALESTATE_USE_BACKEND_ALIASES=false
REALESTATE_ALIASES_JSONL=
REALESTATE_COMMUNITY_POSTS_JSONL=
REALESTATE_REACTION_WINDOW_MINUTES=60
REALESTATE_REACTION_SNAPSHOT_REFRESH_ENABLED=false
REALESTATE_REACTION_SNAPSHOT_REFRESH_INTERVAL_MINUTES=360
REALESTATE_REACTION_USE_CURRENT_WINDOW=false

# Optional daily refresh orchestration.
# Map layer refresh summarizes backend market facts and reaction snapshots into
# map_layer_snapshots for /realestate/map heat layers.
# Evidence log refresh reads latest backend reaction rankings, target market facts,
# and target content candidates, then writes rule-based EvidenceLog records.
REALESTATE_DAILY_REFRESH_ENABLED=false
REALESTATE_DAILY_REFRESH_INTERVAL_MINUTES=360
# Daily MVP reports use 7d TOP rankings by default.
REALESTATE_DAILY_REACTION_WINDOW_MINUTES=10080
REALESTATE_OFFICIAL_STATS_REFRESH_ENABLED=false
REALESTATE_COMPLEX_REGISTRY_REFRESH_ENABLED=false
REALESTATE_COMPLEX_REGISTRY_MARKET_FACT_LIMIT=1000
REALESTATE_TOP10_READINESS_LIMIT=10
REALESTATE_COMMUNITY_COMPLEX_SEED_REFRESH_ENABLED=false
REALESTATE_MAP_LAYER_REFRESH_ENABLED=false
REALESTATE_MAP_LAYER_TYPES=sido,sigungu
REALESTATE_MAP_LAYER_PERIODS=month,quarter,halfYear
REALESTATE_EVIDENCE_LOG_REFRESH_ENABLED=false
REALESTATE_EVIDENCE_TARGET_TYPE=region
REALESTATE_EVIDENCE_RANKING_LIMIT=20
REALESTATE_EVIDENCE_MARKET_FACT_LIMIT=20
REALESTATE_EVIDENCE_CONTENT_LIMIT=20

# Optional SerpApi recent issue discovery.
# Search results are stored as candidate content links, not as interest scores.
SERPAPI_API_KEY=
SERPAPI_RESULT_LIMIT=5
SERPAPI_TIMEOUT_SECONDS=30
KAKAO_SEARCH_TIMEOUT_SECONDS=30
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_SEARCH_TIMEOUT_SECONDS=30
CAFE_SEARCH_QUERY_LIMIT=10
CAFE_SEARCH_RESULT_LIMIT=200
REALESTATE_SEARCH_TARGETS_JSONL=
REALESTATE_ISSUE_KEYWORDS=교통,정책,개발,금리,대출,청약,공급,전세,리포트,영상,블로그

# Optional GMS AI gateway for LLM evaluation and embeddings.
# Keep the real key in local .env, backend application-local.yml, or a secret manager only.
GMS_KEY=
GMS_OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_OPENAI_CHAT_MODEL=gpt-5-mini
GMS_GEMINI_BASE_URL=https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com
GMS_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GMS_TIMEOUT_SECONDS=30
